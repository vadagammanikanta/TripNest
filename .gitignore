# TripNest .gitignore

# ===========================
# Spring Boot / Maven
# ===========================
tripnest/target/
tripnest/*.class
tripnest/*.jar
tripnest/.mvn/wrapper/maven-wrapper.jar

# ===========================
# IntelliJ IDEA
# ===========================
.idea/
*.iml
*.ipr
*.iws

# ===========================
# Eclipse
# ===========================
.classpath
.project
.settings/

# ===========================
# VS Code
# ===========================
.vscode/

# ===========================
# Node / React
# ===========================
tripnest-frontend/node_modules/
tripnest-frontend/build/
tripnest-frontend/.env.local
tripnest-frontend/.env.development.local
tripnest-frontend/.env.test.local
tripnest-frontend/.env.production.local
tripnest-frontend/npm-debug.log*
tripnest-frontend/yarn-debug.log*
tripnest-frontend/yarn-error.log*

# ===========================
# OS Generated
# ===========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ===========================
# Environment / Secrets
# ===========================
.env
*.env
*.env.*
application-local.properties
application-prod.properties
